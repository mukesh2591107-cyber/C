void adc(void)
{ 
    TRISA3 = 1;        
    ADCON1 = 0x8E;     
    ADCON0 = 0x81;     
}


unsigned int ADC_STR(unsigned char k)
{
    unsigned int output;
    
    
    ADCON0 &= 0xC5;
    ADCON0 |= (k << 3); 
    
    __delay_us(20);    
    GO_DONE = 1;       
    
    while(GO_DONE);    
    
    output = ((unsigned int)ADRESH << 8) | ADRESL; 
    return output;
}


void UART_Init(void)
{
    TRISC6 = 1;      
    TRISC7 = 1;      

    SPBRG = 129;     

    BRGH = 1;        
    SYNC = 0;        
    SPEN = 1;        
    TXEN = 1;        
    CREN = 1;        
}


void UART_SendChar(char c)
{
    while(TXIF == 0); 
    TXREG = c;
}

void UART_SendString(const char *s)
{
    while(*s)
    {
        UART_SendChar(*s++);
    }
} 
