#include<stdio.h>
#include<stdlib.h>


int main()
{
    int *ptr;
    int i;

    ptr=(int*)malloc(sizeof(int));
    printf("Enter 3 numbers:\n");
    for(i=0;i<3;i++)
    {
      scanf("%d",&ptr[i]);
    }
    printf("Enter 2 numbers:\n");
    ptr=(int*)realloc(ptr,2*sizeof(int));
    for(i=3;i<5;i++)
    {
      scanf("%d",&ptr[i]);
    }
    printf("The 5 numbers are:\n");
    for(i=0;i<5;i++)
    {
      printf("%d\n",ptr[i]);
    };
    free(ptr);
    return 0;
}
