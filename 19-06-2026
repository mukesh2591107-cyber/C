#include <stdio.h>
#include <stdlib.h>
int main()
{
   int i, n = 5;
    int *ptr;

    ptr = (int*)malloc(n * sizeof(int));
    if (ptr == NULL)
    {
        printf("Memory allocation failed\n");
        return 1;
    }
    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++) 
    {
        scanf("%d", &ptr[i]);
    }
    printf("Elements:\n");
    for (i = 0; i < n; i++)
    {
        printf("%d\n", ptr[i]);
    }
    free(ptr);
    return 0; 
}
