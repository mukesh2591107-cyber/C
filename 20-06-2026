#include<stdio.h>

struct employee
{
    int id;
    char name[50];
    float salary;
};
int main()
{
    struct employee emp[5];
    int new=0;
    printf("enter details of 5 employees:\n");
    for (int i = 0; i < 5; i++) 
    {
        printf("employee %d:\n", i + 1);
        printf("id: ");
        scanf("%d", &emp[i].id);
        printf("name: ");
        scanf(" %s", &emp[i].name); 
        printf("salary: ");
        scanf("%f", &emp[i].salary);

        if (emp[i].salary > emp[new].salary)
        {
            new=i;
        }
        }
    printf("employee with highest salary\n");
    printf("id: %d\n", emp[new].id);
    printf("name: %s\n", emp[new].name);
    printf("salary: %f\n", emp[new].salary);

    return 0;
}
